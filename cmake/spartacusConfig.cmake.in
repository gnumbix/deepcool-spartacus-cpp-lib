@PACKAGE_INIT@

# libspartacus links libusb-1.0. Because the library is built statically, that dependency
# must be re-resolved on the consumer side so the imported target referenced by the exported
# targets file exists.
include(CMakeFindDependencyMacro)
find_dependency(PkgConfig)
pkg_check_modules(SPARTACUS_LIBUSB REQUIRED IMPORTED_TARGET libusb-1.0)

include("${CMAKE_CURRENT_LIST_DIR}/spartacusTargets.cmake")

check_required_components(spartacus)
