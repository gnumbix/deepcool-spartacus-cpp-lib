# Codifies the style the sources already follow. Applies to src/, include/, examples/,
# tests/. Do NOT run on third_party/spartacus_jpeg.h (vendored; keep byte-stable).
BasedOnStyle: Google
Standard: c++17
ColumnLimit: 100
IndentWidth: 4
AccessModifierOffset: -4
DerivePointerAlignment: false
PointerAlignment: Left
AllowShortFunctionsOnASingleLine: Inline
IncludeBlocks: Preserve
